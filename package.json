{
  "name": "qq-cache-image-viewer",
  "version": "0.1.0",
  "description": "QQ 缓存图片查看器 - 智能浏览、搜索和管理 QQ 缓存图片",
  "main": "dist/main/main/index.js",
  "homepage": "./",
  "author": "Your Name",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:react\" \"npm run dev:electron\"",
    "dev:main": "tsc -w -p src/main/tsconfig.json",
    "dev:react": "cross-env BROWSER=none PORT=3001 react-scripts start",
    "dev:electron": "wait-on http://127.0.0.1:3001 && electron .",
    "prebuild": "node scripts/clean-build.js",
    "build": "npm run build:react && npm run build:electron && npm run move:build",
    "build:react": "react-scripts build",
    "build:electron": "tsc -p src/main/tsconfig.json",
    "move:build": "node scripts/move-build.js",
    "postbuild": "echo 'Build complete: dist/main and dist/renderer ready'",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:nsis": "npm run build && electron-builder --win nsis",
    "dist:portable": "npm run build && electron-builder --win portable",
    "dist:all": "npm run dist",
    "test": "react-scripts test",
    "test:unit": "jest --testPathPattern=\\\\.test\\\\.tsx?$",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "eject": "react-scripts eject",
    "start": "electron ."
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.1.0",
    "adm-zip": "^0.5.16",
    "antd": "^5.13.2",
    "better-sqlite3": "^9.4.0",
    "electron-store": "^8.2.0",
    "fs-extra": "^11.2.0",
    "i18next": "^23.8.2",
    "p-limit": "^7.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^14.0.1",
    "react-redux": "^9.1.0",
    "sharp": "^0.33.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/adm-zip": "^0.5.7",
    "@types/better-sqlite3": "^7.6.9",
    "@types/electron": "^1.6.10",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.16",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.2.1",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.33",
    "react-scripts": "5.0.1",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3",
    "wait-on": "^7.2.0"
  },
  "overrides": {
    "typescript": "^5.3.3"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
